    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "ics": "^3.12.0",
    "lucide-react": "^0.577.0",
    "match-sorter": "^8.3.0",
