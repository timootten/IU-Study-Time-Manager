# Local PostgreSQL (Docker Compose)
DATABASE_URL=postgresql://stm:postgres@localhost:5432/stm

# Better Auth
BETTER_AUTH_SECRET=replace-with-a-random-secret-at-least-32-characters
BETTER_AUTH_URL=http://localhost:3000

# Client
VITE_APP_URL=http://localhost:3000

# SMTP (password reset emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM=Study Time Manager <noreply@example.com>

# Web Push (VAPID) — generate with: bun --bun node -e "const w=require('web-push'); console.log(w.generateVAPIDKeys())"
VAPID_SUBJECT=mailto:admin@example.com
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Client Web Push
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key